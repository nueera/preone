generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  PARENT
  TASK_MASTER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  username      String?   @unique
  role          Role      @default(PARENT)
  avatar        String?
  isActive      Boolean   @default(true)
  schoolId      String?
  branchId      String?
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  school        School?   @relation(fields: [schoolId], references: [id])
  branch        Branch?   @relation(fields: [branchId], references: [id])
  auditLogs     AuditLog[]
  teacher       Teacher?
  crmTasks      CrmTask[]
  crmTasksAssigned CrmTask[] @relation("CrmTaskAssignee")
  notifications       Notification[]  @relation("UserNotifications")
  sentNotifications   Notification[]  @relation("SentNotifications")
  chatThreads         ChatParticipant[]
  sentMessages        Message[]
  announcementReads   AnnouncementRead[]
  createdAnnouncements Announcement[]
  sessions            Session[]
  accounts            Account[]
  refreshTokens       RefreshToken[]
  errorLogs           ErrorLog[]
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  code      String
  purpose   String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model School {
  id                  String             @id @default(cuid())
  name                String
  logo                String?
  address             String?
  city                String?
  state               String?
  pincode             String?
  phone               String?
  email               String?
  website             String?
  academicYear        String?
  board               String?
  schoolCode          String?
  country             String?
  theme               String?            // space, rainbow, animals, fairytale, nature, adventure
  onboardingComplete  Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  branches            Branch[]
  settings            SchoolSetting[]
  users               User[]
  notifications       Notification[]
  dailyUpdateConfig   DailyUpdateConfig?
  onboardingDrafts    OnboardingDraft[]
  chatThreads         ChatThread[]
  announcements       Announcement[]
}

model Branch {
  id            String   @id @default(cuid())
  schoolId      String
  name          String
  code          String?
  address       String?
  phone         String?
  capacity      Int      @default(0)
  startTime     String   @default("08:00")
  endTime       String   @default("14:00")
  workingDays   String   @default("[1,2,3,4,5]")
  isHeadOffice  Boolean  @default(false)
  inChargeName  String?
  inChargePhone String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  school        School   @relation(fields: [schoolId], references: [id])
  users         User[]
  classes       Class[]
  students      Student[]
  teachers      Teacher[]
  programs      Program[]
  chatThreads   ChatThread[]
}

model SchoolSetting {
  id        String   @id @default(cuid())
  schoolId  String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
  @@unique([schoolId, key])
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
}

model Student {
  id            String        @id @default(cuid())
  firstName     String
  lastName      String
  dob           DateTime
  gender        String
  bloodGroup    String?
  aadhaarNumber String?
  photo         String?
  admissionDate DateTime      @default(now())
  status        StudentStatus @default(ACTIVE)
  rollNumber    String?
  classId       String?
  branchId      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  class         Class?        @relation(fields: [classId], references: [id])
  branch        Branch?       @relation(fields: [branchId], references: [id])
  parents       StudentParent[]
  medicalRecords MedicalRecord[]
  siblingsAsStudent Sibling[]  @relation("StudentSiblings")
  siblingsAsSibling Sibling[]  @relation("SiblingOf")
  attendance    StudentAttendance[]
  invoices      Invoice[]
  payments      Payment[]
  growthScores  GrowthScore[]
  dailyUpdates  DailyUpdate[]
  observations  Observation[]
  pickupDrops   PickupDrop[]
  memories      Memory[]
  achievements  Achievement[]
  certificates  Certificate[]
  milestoneTimelines MilestoneTimeline[]
  aiObservations AIObservation[]
}

model Parent {
  id                 String        @id @default(cuid())
  firstName          String
  lastName           String
  phone              String
  email              String?
  occupation         String?
  address            String?
  relation           String
  isEmergencyContact Boolean       @default(false)
  photo              String?
  kycDoc             String?
  kycStatus          String?
  kycRejectionReason String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  students           StudentParent[]
  kycDocuments       KycDocument[]
  notificationPreferences NotificationPreference?
}

model StudentParent {
  id        String  @id @default(cuid())
  studentId String
  parentId  String
  isPrimary Boolean @default(false)
  student   Student @relation(fields: [studentId], references: [id])
  parent    Parent  @relation(fields: [parentId], references: [id])
  @@unique([studentId, parentId])
}

model Sibling {
  id        String  @id @default(cuid())
  studentId String
  siblingId String
  relation  String?
  student   Student @relation("StudentSiblings", fields: [studentId], references: [id])
  sibling   Student @relation("SiblingOf", fields: [siblingId], references: [id])
}

model MedicalRecord {
  id                String   @id @default(cuid())
  studentId         String
  allergies         String?
  conditions        String?
  medications       String?
  vaccinationStatus String?
  doctorName        String?
  doctorPhone       String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  student           Student  @relation(fields: [studentId], references: [id])
}

enum TeacherStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
}

model Teacher {
  id             String        @id @default(cuid())
  userId         String?       @unique
  firstName      String
  lastName       String
  email          String        @unique
  phone          String
  dob            DateTime?
  gender         String?
  address        String?
  qualification  String?
  specialization String?
  experience     Int           @default(0)
  photo          String?
  joiningDate    DateTime      @default(now())
  status         TeacherStatus @default(ACTIVE)
  branchId       String?
  salary         Float?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User?         @relation(fields: [userId], references: [id])
  branch         Branch?       @relation(fields: [branchId], references: [id])
  qualifications TeacherQualification[]
  workSchedules  WorkSchedule[]
  reviews        PerformanceReview[]
  salaries       SalaryRecord[]
  leaves         Leave[]
  staffAttendance StaffAttendance[]
  assignedClass  Class?
}

model TeacherQualification {
  id          String   @id @default(cuid())
  teacherId   String
  degree      String
  institution String
  year        Int
  certificate String?
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
}

model WorkSchedule {
  id        String   @id @default(cuid())
  teacherId String
  dayOfWeek Int
  startTime String
  endTime   String
  subject   String?
  classId   String?
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
}

model PerformanceReview {
  id                String   @id @default(cuid())
  teacherId         String
  period            String
  teachingQuality   Int
  studentEngagement Int
  communication     Int
  punctuality       Int
  professionalDev   Int
  overallRating     Float
  comments          String?
  reviewerName      String?
  reviewDate        DateTime @default(now())
  teacher           Teacher  @relation(fields: [teacherId], references: [id])
}

enum SalaryStatus {
  PENDING
  PAID
  CANCELLED
}

model SalaryRecord {
  id              String       @id @default(cuid())
  teacherId       String
  month           Int
  year            Int
  basicSalary     Float
  hra             Float        @default(0)
  da              Float        @default(0)
  pfDeduction     Float        @default(0)
  taxDeduction    Float        @default(0)
  otherDeductions Float        @default(0)
  deductionReason String?
  bonus           Float        @default(0)
  bonusReason     String?
  netPay          Float
  paymentMethod   String?
  paymentDate     DateTime?
  status          SalaryStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  teacher         Teacher      @relation(fields: [teacherId], references: [id])
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  MATERNITY
  PATERNITY
  WITHOUT_PAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Leave {
  id         String      @id @default(cuid())
  teacherId  String
  leaveType  LeaveType
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     LeaveStatus @default(PENDING)
  approvedBy String?
  approvedAt DateTime?
  createdAt  DateTime    @default(now())
  teacher    Teacher     @relation(fields: [teacherId], references: [id])
}

model Program {
  id          String   @id @default(cuid())
  name        String
  description String?
  ageMin      Int
  ageMax      Int
  branchId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  branch      Branch?  @relation(fields: [branchId], references: [id])
  classes     Class[]
}

model Class {
  id        String   @id @default(cuid())
  name      String
  programId String
  section   String?
  branchId  String?
  capacity  Int      @default(30)
  teacherId String?  @unique
  roomNo    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  program   Program  @relation(fields: [programId], references: [id])
  branch    Branch?  @relation(fields: [branchId], references: [id])
  students  Student[]
  activities Activity[]
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
  sections  Section[]
  chatThreads ChatThread[]
}

model Section {
  id      String @id @default(cuid())
  name    String
  classId String
  class   Class  @relation(fields: [classId], references: [id])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model StudentAttendance {
  id           String           @id @default(cuid())
  studentId    String
  date         DateTime
  status       AttendanceStatus
  checkInTime  String?
  checkOutTime String?
  method       String?
  markedBy     String?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime         @default(now())
  student      Student          @relation(fields: [studentId], references: [id])
  @@unique([studentId, date])
}

model StaffAttendance {
  id           String           @id @default(cuid())
  teacherId    String
  date         DateTime
  status       AttendanceStatus
  checkInTime  String?
  checkOutTime String?
  method       String?
  markedBy     String?
  createdAt    DateTime         @default(now())
  teacher      Teacher          @relation(fields: [teacherId], references: [id])
  @@unique([teacherId, date])
}

enum FeeType {
  TUITION
  TRANSPORT
  ACTIVITY
  EXAM
  LABORATORY
  LIBRARY
  DEVELOPMENT
  OTHER
}

enum FeeFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUAL
  ONE_TIME
}

model FeeStructure {
  id          String        @id @default(cuid())
  name        String
  type        FeeType
  amount      Float
  frequency   FeeFrequency
  classId     String?
  programId   String?
  description String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  invoices    Invoice[]
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNo      String        @unique
  studentId      String
  feeStructureId String?
  amount         Float
  discount       Float         @default(0)
  netAmount      Float
  status         InvoiceStatus @default(PENDING)
  dueDate        DateTime
  paidDate       DateTime?
  description    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  student        Student       @relation(fields: [studentId], references: [id])
  feeStructure   FeeStructure? @relation(fields: [feeStructureId], references: [id])
  payments       Payment[]
  receipt        Receipt?
  refund         Refund?
  reminders      FeeReminder[]
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  studentId     String
  amount        Float
  method        PaymentMethod
  transactionRef String?
  chequeNo      String?
  bankName      String?
  paymentDate   DateTime
  notes         String?
  createdAt     DateTime      @default(now())
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  student       Student       @relation(fields: [studentId], references: [id])
}

model Receipt {
  id        String   @id @default(cuid())
  invoiceId String   @unique
  receiptNo String   @unique
  amount    Float
  pdfUrl    String?
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
}

enum RefundReason {
  WITHDRAWAL
  DUPLICATE
  ERROR
  OTHER
}

enum RefundStatus {
  PENDING
  APPROVED
  PROCESSED
  REJECTED
}

model Refund {
  id          String       @id @default(cuid())
  invoiceId   String       @unique
  amount      Float
  reason      RefundReason
  method      String
  bankAccount String?
  bankIfsc    String?
  notes       String?
  status      RefundStatus @default(PENDING)
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  invoice     Invoice      @relation(fields: [invoiceId], references: [id])
}

model FeeReminder {
  id        String   @id @default(cuid())
  invoiceId String
  type      String
  channel   String
  sentAt    DateTime?
  status    String
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
}

enum ActivityType {
  ART
  MUSIC
  DANCE
  SPORTS
  ACADEMIC
  OUTDOOR
  INDOOR
  CRAFT
}

enum ActivityStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

model Activity {
  id               String         @id @default(cuid())
  title            String
  type             ActivityType
  description      String?
  date             DateTime
  startTime        String?
  endTime          String?
  location         String?
  materials        String?
  learningOutcomes String?
  media            String?
  isPublished      Boolean        @default(false)
  publishedAt      DateTime?
  status           ActivityStatus @default(UPCOMING)
  classId          String?
  createdBy        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  class            Class?         @relation(fields: [classId], references: [id])
}

enum ObservationCategory {
  BEHAVIORAL
  ACADEMIC
  SOCIAL
  EMOTIONAL
  PHYSICAL
  COGNITIVE
}

enum Priority {
  LOW
  NORMAL
  HIGH
  CONCERN
}

model Observation {
  id            String              @id @default(cuid())
  studentId     String
  teacherId     String?
  category      ObservationCategory
  content       String
  priority      Priority
  isShared      Boolean             @default(false)
  parentAck     Boolean             @default(false)
  parentComment String?
  media         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  student       Student             @relation(fields: [studentId], references: [id])
}

model DailyUpdate {
  id            String   @id @default(cuid())
  studentId     String
  date          DateTime
  breakfast     String?
  breakfastMenu String?
  lunch         String?
  lunchMenu     String?
  snacks        String?
  snacksMenu    String?
  sleepStart    String?
  sleepEnd      String?
  sleepQuality  String?
  moodMorning   String?
  moodAfternoon String?
  pottyCount    Int      @default(0)
  pottyType     String?
  waterGlasses  Int      @default(0)
  highlights    String?
  status        String   @default("DRAFT")
  publishedAt   DateTime?
  teacherId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  student       Student  @relation(fields: [studentId], references: [id])
  @@unique([studentId, date])
}

// ============================================
// COMMUNICATION — Chat + Announcements
// ============================================

enum ChatThreadType {
  DIRECT
  CLASS_GROUP
  BRANCH_GROUP
  CUSTOM_GROUP
}

model ChatThread {
  id                   String            @id @default(cuid())
  type                 ChatThreadType     @default(DIRECT)
  name                 String?            // Group name (null for DMs)
  schoolId             String
  branchId             String?
  classId              String?
  lastMessagePreview   String?            // Cached last message text
  lastMessageAt        DateTime?          // Cached timestamp
  onlyAdminsCanMessage Boolean            @default(false)
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  school               School             @relation(fields: [schoolId], references: [id])
  branch               Branch?            @relation(fields: [branchId], references: [id])
  class                Class?             @relation(fields: [classId], references: [id])
  participants         ChatParticipant[]
  messages             Message[]
}

model ChatParticipant {
  id           String     @id @default(cuid())
  threadId     String
  userId       String
  role         String     @default("member")  // admin, member
  unreadCount  Int        @default(0)
  lastReadAt   DateTime?
  isMuted      Boolean    @default(false)
  isPinned     Boolean    @default(false)
  joinedAt     DateTime   @default(now())
  leftAt       DateTime?

  thread       ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])

  @@unique([threadId, userId])
  @@index([userId, lastReadAt])
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  VOICE
  ANNOUNCEMENT
  SYSTEM
}

model Message {
  id            String      @id @default(cuid())
  threadId      String
  senderId      String
  content       String
  type          MessageType @default(TEXT)
  mediaUrl      String?
  mediaThumbnail String?
  mediaType     String?     // image/jpeg, application/pdf, audio/ogg
  mediaSize     Int?
  replyToId     String?
  isEdited      Boolean     @default(false)
  isDeleted     Boolean     @default(false)
  reactions     String      @default("{}")   // JSON: {"emoji": ["userId1", "userId2"]}
  metadata      String      @default("{}")   // JSON: extra data (announcementId, etc.)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  thread        ChatThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender        User        @relation(fields: [senderId], references: [id])
  replyTo       Message?    @relation("MessageReplies", fields: [replyToId], references: [id])
  replies       Message[]   @relation("MessageReplies")

  @@index([threadId, createdAt])
  @@index([senderId])
}

model MessageReadReceipt {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

enum AnnouncementType {
  GENERAL
  EVENT
  HOLIDAY
  FEE_REMINDER
  EMERGENCY
  ACHIEVEMENT
  CONCERN
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  EXPIRED
}

model Announcement {
  id              String             @id @default(cuid())
  schoolId        String
  title           String
  content         String
  type            AnnouncementType    @default(GENERAL)
  priority        Priority           @default(NORMAL)
  target          String             @default("ALL")   // ALL, BRANCH, CLASS, TEACHERS, PARENTS, SPECIFIC
  targetIds       String?            // JSON array of userIds for SPECIFIC target
  branchId        String?
  classId         String?

  // Media
  attachments     String?            @default("[]")    // JSON: [{url, name, type, size}]
  coverImage      String?

  // Publishing
  status          AnnouncementStatus @default(DRAFT)
  publishedAt     DateTime?
  scheduledAt     DateTime?
  expiresAt       DateTime?

  // Delivery channels
  channels        String             @default("[\"app\"]")  // JSON: ["app", "email", "sms", "whatsapp"]
  sendAsChat      Boolean            @default(true)

  // Author
  createdBy       String?

  // Read tracking
  totalRecipients Int                @default(0)

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  school          School             @relation(fields: [schoolId], references: [id])
  creator         User?              @relation(fields: [createdBy], references: [id])
  reads           AnnouncementRead[]

  @@index([schoolId, status])
  @@index([schoolId, publishedAt])
  @@index([scheduledAt])
}

model AnnouncementRead {
  id              String   @id @default(cuid())
  announcementId  String
  userId          String
  readAt          DateTime @default(now())

  announcement    Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user            User @relation(fields: [userId], references: [id])

  @@unique([announcementId, userId])
  @@index([announcementId])
  @@index([userId])
}

model GrowthScore {
  id            String   @id @default(cuid())
  studentId     String
  period        String
  creativity    Int      @default(0)
  communication Int      @default(0)
  social        Int      @default(0)
  confidence    Int      @default(0)
  cognitive     Int      @default(0)
  physical      Int      @default(0)
  overall       Float?
  comments      String?
  assessedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  student       Student  @relation(fields: [studentId], references: [id])
  @@unique([studentId, period])
}

model AIObservation {
  id         String   @id @default(cuid())
  studentId  String
  insight    String
  dimension  String?
  severity   String?
  isActioned Boolean  @default(false)
  createdAt  DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id])
}

model Milestone {
  id          String @id @default(cuid())
  name        String
  ageGroup    String
  category    String
  description String?
}

model MilestoneTimeline {
  id           String    @id @default(cuid())
  studentId    String
  milestoneId  String
  achievedDate DateTime?
  status       String    @default("PENDING")
  notes        String?
  student      Student   @relation(fields: [studentId], references: [id])
}

model Memory {
  id          String   @id @default(cuid())
  studentId   String
  title       String
  description String?
  mediaUrl    String?
  mediaType   String?
  date        DateTime?
  createdAt   DateTime @default(now())
  student     Student  @relation(fields: [studentId], references: [id])
}

model Achievement {
  id          String   @id @default(cuid())
  studentId   String
  title       String
  description String?
  icon        String?
  date        DateTime?
  createdAt   DateTime @default(now())
  student     Student  @relation(fields: [studentId], references: [id])
}

model Certificate {
  id        String   @id @default(cuid())
  studentId String
  title     String
  template  String?
  pdfUrl    String?
  issuedAt  DateTime?
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])
}

enum LeadSource {
  INSTAGRAM
  FACEBOOK
  GOOGLE
  WALK_IN
  REFERRAL
  WEBSITE
  JUSTDIAL
  SULEKHA
  NEWSPAPER
  HOARDING
  EVENT
  OTHER
}

enum LeadStage {
  NEW
  CONTACTED
  VISITED
  APPLIED
  ENROLLED
  LOST
}

model Lead {
  id                String     @id @default(cuid())
  parentName        String
  parentPhone       String
  parentEmail       String?
  childName         String
  childAge          String?
  source            LeadSource
  stage             LeadStage  @default(NEW)
  priority          Priority   @default(NORMAL)
  programInterest   String?
  estimatedValue    Float?
  assignedTo        String?
  notes             String?
  nextFollowUp      DateTime?
  convertedStudentId String?
  lostReason        String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  followUps         FollowUp[]
  crmTasks          CrmTask[]
}

model FollowUp {
  id            String    @id @default(cuid())
  leadId        String
  type          String
  dateTime      DateTime
  outcome       String
  nextFollowUp  DateTime?
  notes         String
  createdBy     String?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  lead          Lead      @relation(fields: [leadId], references: [id])
}

enum CrmTaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum CrmTaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model CrmTask {
  id          String         @id @default(cuid())
  schoolId    String?
  title       String
  description String?
  leadId      String?
  assignedTo  String?
  dueDate     DateTime?
  priority    CrmTaskPriority @default(MEDIUM)
  status      CrmTaskStatus   @default(TODO)
  createdBy   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  lead        Lead?           @relation(fields: [leadId], references: [id])
  assignee    User?           @relation("CrmTaskAssignee", fields: [assignedTo], references: [id])
  creator     User?           @relation(fields: [createdBy], references: [id])
}

model Route {
  id         String    @id @default(cuid())
  name       String
  startPoint String
  endPoint   String
  stops      String?
  distance   Float?
  fee        Float?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  vehicles   Vehicle[]
}

model Vehicle {
  id              String   @id @default(cuid())
  vehicleNo       String
  type            String
  capacity        Int
  routeId         String?
  driverName      String
  driverPhone     String
  driverLicense   String?
  insuranceExpiry DateTime?
  fitnessExpiry   DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  route           Route?   @relation(fields: [routeId], references: [id])
  pickupDrops     PickupDrop[]
}

model Driver {
  id            String   @id @default(cuid())
  name          String
  phone         String
  licenseNo     String
  licenseExpiry DateTime?
  address       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model PickupDrop {
  id        String   @id @default(cuid())
  studentId String
  vehicleId String
  type      String
  location  String?
  time      String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  startTime   String?
  endTime     String?
  venue       String?
  type        String?
  isHoliday   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Holiday {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  type      String?
  createdAt DateTime @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id])
  userId    String
  user      User      @relation("UserNotifications", fields: [userId], references: [id])
  title     String
  message   String
  type      String    @default("INFO")
  category  String    @default("SYSTEM")
  link      String?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  senderId  String?
  sender    User?     @relation("SentNotifications", fields: [senderId], references: [id])
  createdAt DateTime  @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([schoolId, category])
}

model KycDocument {
  id           String   @id @default(cuid())
  parentId     String
  documentType String
  documentUrl  String
  status       String   @default("PENDING")
  reviewedBy   String?
  reviewedAt   DateTime?
  rejectionReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  parent       Parent   @relation(fields: [parentId], references: [id])
}

model NotificationPreference {
  id                    String   @id @default(cuid())
  parentId              String   @unique
  dailyUpdateApp        Boolean  @default(true)
  dailyUpdateSms        Boolean  @default(false)
  dailyUpdateEmail      Boolean  @default(false)
  observationApp        Boolean  @default(true)
  observationSms        Boolean  @default(true)
  observationEmail      Boolean  @default(false)
  feeReminderApp        Boolean  @default(true)
  feeReminderSms        Boolean  @default(true)
  feeReminderEmail      Boolean  @default(true)
  feeOverdueApp         Boolean  @default(true)
  feeOverdueSms         Boolean  @default(true)
  feeOverdueEmail       Boolean  @default(true)
  attendanceApp         Boolean  @default(false)
  attendanceSms         Boolean  @default(false)
  attendanceEmail       Boolean  @default(false)
  announcementApp       Boolean  @default(true)
  announcementSms       Boolean  @default(false)
  announcementEmail     Boolean  @default(true)
  teacherMessageApp     Boolean  @default(true)
  teacherMessageSms     Boolean  @default(false)
  teacherMessageEmail   Boolean  @default(false)
  leaveStatusApp        Boolean  @default(true)
  leaveStatusSms        Boolean  @default(false)
  leaveStatusEmail      Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  parent                Parent   @relation(fields: [parentId], references: [id])
}

model Report {
  id          String   @id @default(cuid())
  title       String
  type        String
  generatedBy String?
  fileUrl     String?
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Reaction {
  id          String   @id @default(cuid())
  studentId   String
  parentId    String
  targetType  String   // 'memory' | 'achievement' | 'certificate'
  targetId    String
  reaction    String   // 'love' | 'celebrate' | 'proud' | 'wow' | 'heart'
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([parentId, targetType, targetId])
  @@index([studentId, targetType, targetId])
}

model DailyUpdateConfig {
  id              String   @id @default(cuid())
  schoolId        String   @unique
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // What updates to send
  sendAttendance  Boolean  @default(true)
  sendMood        Boolean  @default(true)
  sendActivities  Boolean  @default(true)
  sendMeals       Boolean  @default(true)
  sendNap         Boolean  @default(true)
  sendPhotos      Boolean  @default(true)
  sendNotes       Boolean  @default(true)

  // When to send
  sendTime        String   @default("end_of_day")        // real_time, hourly, end_of_day
  sendAt          String?                                  // Specific time if end_of_day (e.g., "14:30")

  // Parent notification preferences
  notifyVia       String   @default("app,email")          // comma-separated: app, email, sms, whatsapp

  // Templates
  templates       String   @default("{}")                 // JSON string for custom message templates per type

  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum OnboardingSessionStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

model OnboardingDraft {
  id              String                  @id @default(cuid())
  schoolId        String
  school          School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name            String                  @default("New Setup")
  status          OnboardingSessionStatus @default(DRAFT)
  academicYear    String?                                           // e.g. "2025-2026"

  currentStep     Int                     @default(0)
  completedSteps  String                  @default("[]")              // JSON array: [0, 1, 2, ...]

  // Step data (saved as draft so user can resume)
  step1School     String?                                           // JSON string
  step2Branch     String?                                           // JSON string
  step3Academic   String?                                           // JSON string
  step4Subjects   String?                                           // JSON string
  step5Teachers   String?                                           // JSON string
  step6Students   String?                                           // JSON string
  step7Updates    String?                                           // JSON string

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([schoolId, status])
}

// ============================================
// NextAuth Required Models
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// ERROR LOGGING SYSTEM
// ============================================

enum ErrorSource {
  FRONTEND
  BACKEND
  DATABASE
  AUTH
  EXTERNAL
  SOCKET
}

enum ErrorSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ErrorStatus {
  NEW
  ACKNOWLEDGED
  INVESTIGATING
  RESOLVED
  IGNORED
}

model ErrorLog {
  id              String         @id @default(cuid())
  fingerprint     String         @unique                        // Hash for deduplication
  message         String                                         // Error message
  stack           String?                                        // Full stack trace
  type            String?                                        // Error class name (TypeError, ReferenceError, etc.)
  source          ErrorSource                                    // Where it happened
  severity        ErrorSeverity  @default(MEDIUM)
  status          ErrorStatus    @default(NEW)

  // Context — WHERE it happened
  url             String?
  method          String?
  apiRoute        String?
  lineNumber      Int?
  columnName      Int?
  fileName        String?

  // Context — WHO & WHEN
  userId          String?
  userRole        String?
  schoolId        String?
  sessionId       String?
  userAgent       String?
  ipAddress       String?

  // Request/Response
  requestBody     String?
  requestQuery    String?
  statusCode      Int?
  responseBody    String?

  // Occurrence tracking
  occurrenceCount Int            @default(1)
  firstSeenAt     DateTime       @default(now())
  lastSeenAt      DateTime       @default(now())

  // Resolution
  resolvedBy      String?
  resolvedAt      DateTime?
  resolutionNote  String?
  fixVersion      String?

  // Tags & Metadata
  tags            String         @default("[]")
  metadata        String         @default("{}")
  breadcrumbs     String         @default("[]")

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  user            User?          @relation(fields: [userId], references: [id])

  @@index([source, severity])
  @@index([status])
  @@index([userId])
  @@index([schoolId])
  @@index([lastSeenAt])
  @@index([severity, status])
  @@index([firstSeenAt])
}
