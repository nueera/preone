# ============================================================
# PreOne — Environment Variables Template
# Copy this to .env and fill in your values
# ============================================================

# ---- Database (PostgreSQL) ----
# Local development (with Docker Compose):
DATABASE_URL="postgresql://preone:preone_dev_2024@localhost:5432/preone_dev?schema=public"

# Production example:
# DATABASE_URL="postgresql://preone:your_secure_password@postgres:5432/preone?schema=public"

# ---- Auth ----
# MUST be at least 32 characters in production!
# Generate with: openssl rand -hex 32
JWT_SECRET="your-secret-key-here-min-32-chars"
JWT_EXPIRY="24h"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="PreOne"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"
# With password: redis://:your_password@localhost:6379

# ---- Socket.io CORS ----
# Comma-separated list of allowed origins. Use "*" for dev only.
SOCKET_CORS_ORIGINS="*"

# ---- Docker Compose (used by docker-compose.yml) ----
POSTGRES_USER=preone
POSTGRES_PASSWORD=preone_secret_2024
POSTGRES_DB=preone
POSTGRES_PORT=5432
REDIS_PASSWORD=preone_redis_2024
REDIS_PORT=6379
APP_PORT=3000
